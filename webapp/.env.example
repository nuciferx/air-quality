# ── Xiaomi MiCloud credentials ────────────────────────────────────────────────
XIAOMI_USER_ID=your_user_id_here
XIAOMI_SERVICE_TOKEN=your_service_token_here
XIAOMI_SSECURITY=your_ssecurity_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The spreadsheet ID from the URL: /spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=your_sheet_id_here

# Service account key as a single-line JSON string (for production/CI)
# For local dev you can put the key in creds.json instead (see README)
GCP_SA_KEY={"type":"service_account","project_id":"..."}
